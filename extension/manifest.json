{
  "manifest_version": 3,
  "name": "Phishing Shield AI",
  "version": "1.0.0",
  "description": "Real-time phishing site interception using asynchronous heuristics and ML verification.",
  "permissions": [
    "tabs",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}